{
    "compilerOptions": {
        "target": "ES2020",
        "module": "CommonJS",
        "strict": false,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "paths": {
            "@/*": ["./*"]
        }
    },
    "include": ["**/*.js", "**/*.json"],
    "exclude": ["node_modules"]
}
