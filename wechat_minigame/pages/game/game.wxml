<!--pages/game/game.wxml-->
<view class="game-container">
    <!-- 游戏信息栏 -->
    <view class="game-header">
        <view class="game-title">{{gameInfo.name}}</view>
        <view class="game-stats">
            <view class="score">得分: {{score}}</view>
            <view class="high-score">最高: {{highScore}}</view>
        </view>
        <view class="menu-btn" bindtap="onToggleMenu">☰</view>
    </view>

    <!-- 游戏画布 -->
    <view class="canvas-container">
        <canvas
            type="2d"
            id="gameCanvas"
            class="game-canvas"
            wx:if="{{gameLoaded}}"
        ></canvas>
        <view class="game-placeholder" wx:else>
            <text>游戏加载中...</text>
        </view>
    </view>

    <!-- 底部控制区 -->
    <view class="game-controls">
        <view class="control-btn restart" bindtap="onRestart">🔄 重新开始</view>
        <view class="control-btn back" bindtap="onBackToHall">🏠 大厅</view>
    </view>

    <!-- 菜单弹窗 -->
    <view class="menu-overlay" wx:if="{{showMenu}}" bindtap="onToggleMenu">
        <view class="menu-content" catchtap="">
            <view class="menu-title">游戏菜单</view>
            <view class="menu-item" bindtap="onRestart">🔄 重新开始</view>
            <view class="menu-item" bindtap="onPause">⏸️ 暂停/继续</view>
            <view class="menu-item" bindtap="onBackToHall">🏠 返回大厅</view>
        </view>
    </view>
</view>
