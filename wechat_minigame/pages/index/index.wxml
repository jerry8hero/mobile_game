<!--pages/index/index.wxml-->
<view class="container">
    <!-- 顶部搜索栏 -->
    <view class="search-bar">
        <input
            class="search-input"
            placeholder="搜索游戏..."
            placeholder-class="search-placeholder"
            value="{{searchQuery}}"
            bindinput="onSearchInput"
            confirm-type="search"
        />
        <view class="search-close" bindtap="onCloseSearch" wx:if="{{showSearch || searchQuery}}">✕</view>
    </view>

    <!-- 搜索结果 -->
    <view class="search-results" wx:if="{{showSearch}}">
        <view class="results-header">
            <text>搜索结果: {{searchResults.length}} 个</text>
            <text class="back-btn" bindtap="onCloseSearch">返回</text>
        </view>
        <view class="games-list">
            <block wx:for="{{searchResults}}" wx:key="gameId">
                <view class="game-card" bindtap="onGameTap" data-gameid="{{item.gameId}}">
                    <text class="game-icon">{{item.icon}}</text>
                    <view class="game-info">
                        <text class="game-name">{{item.name}}</text>
                        <text class="game-type">{{item.type}}</text>
                    </view>
                    <view
                        class="fav-btn {{favorites.indexOf(item.gameId) >= 0 ? 'active' : ''}}"
                        catchtap="onToggleFavorite"
                        data-gameid="{{item.gameId}}"
                        data-gamename="{{item.name}}"
                        data-gameicon="{{item.icon}}"
                        data-gametype="{{item.type}}"
                        data-category="{{item.category}}"
                    >
                        {{favorites.indexOf(item.gameId) >= 0 ? '❤️' : '🤍'}}
                    </view>
                </view>
            </block>
        </view>
    </view>

    <!-- 游戏分类网格 -->
    <scroll-view class="content" scroll-y wx:if="{{!showCategory && !showSearch}}">
        <view class="category-grid">
            <block wx:for="{{categories}}" wx:key="name">
                <view
                    class="category-card"
                    style="border-color: {{item.color}}"
                    bindtap="onCategoryTap"
                    data-index="{{index}}"
                >
                    <view class="category-icon">{{item.icon}}</view>
                    <view class="category-name">{{item.name}}</view>
                    <view class="category-count">{{item.count}} 个游戏</view>
                </view>
            </block>
        </view>
    </scroll-view>

    <!-- 游戏列表 -->
    <scroll-view class="content" scroll-y wx:if="{{showCategory && !showSearch}}">
        <view class="game-list-header">
            <view class="back-to-categories" bindtap="onBackToCategories">← 返回分类</view>
            <view class="category-title">{{currentCategory.icon}} {{currentCategory.name}}</view>
        </view>
        <view class="games-list">
            <block wx:for="{{games}}" wx:key="gameId">
                <view class="game-card" bindtap="onGameTap" data-gameid="{{item.gameId}}">
                    <text class="game-icon">{{item.icon}}</text>
                    <view class="game-info">
                        <text class="game-name">{{item.name}}</text>
                        <text class="game-type">{{item.type}}</text>
                    </view>
                    <view
                        class="fav-btn {{favorites.indexOf(item.gameId) >= 0 ? 'active' : ''}}"
                        catchtap="onToggleFavorite"
                        data-gameid="{{item.gameId}}"
                        data-gamename="{{item.name}}"
                        data-gameicon="{{item.icon}}"
                        data-gametype="{{item.type}}"
                        data-category="{{currentCategory.name}}"
                    >
                        {{favorites.indexOf(item.gameId) >= 0 ? '❤️' : '🤍'}}
                    </view>
                </view>
            </block>
        </view>
    </scroll-view>

    <!-- 底部标签栏 -->
    <view class="tab-bar">
        <view class="tab-item active">
            <text class="tab-icon">🏠</text>
            <text>首页</text>
        </view>
        <view class="tab-item">
            <text class="tab-icon">❤️</text>
            <text>收藏</text>
        </view>
        <view class="tab-item">
            <text class="tab-icon">⚙️</text>
            <text>设置</text>
        </view>
    </view>

    <!-- 平台标识 -->
    <view class="platform-tag" wx:if="{{platform === 'wechat'}}">微信</view>
</view>
